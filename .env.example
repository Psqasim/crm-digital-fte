# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Neon PostgreSQL (Phase 4A)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Test database (used by production/tests/test_database.py — leave unset to skip DB tests)
TEST_DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb_test?sslmode=require

# Kafka (Phase 4C)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Gmail (Phase 4C — OAuth2 credentials file path)
GMAIL_CREDENTIALS_JSON=/path/to/gmail-credentials.json
GMAIL_USER_EMAIL=support@nexaflow.io
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Twilio WhatsApp (Phase 4C)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # from twilio.com/console
TWILIO_AUTH_TOKEN=your_auth_token_here                # from twilio.com/console
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886          # Twilio sandbox or approved number
