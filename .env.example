# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Neon PostgreSQL (Phase 4A)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Test database (used by production/tests/test_database.py — leave unset to skip DB tests)
TEST_DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb_test?sslmode=require

# Kafka (Phase 4C)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Gmail (Phase 4D)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Twilio WhatsApp (Phase 4D)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
