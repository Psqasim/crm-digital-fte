# Version control
.git/
.gitignore

# Environment files — never include secrets in images
.env
.env.*
!.env.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# Node
src/web-form/node_modules/
src/web-form/.next/
src/web-form/.npm/

# Docker files themselves
**/Dockerfile*
.dockerignore
production/docker-compose.yml

# Logs
*.log
logs/

# Testing
.pytest_cache/
htmlcov/
.coverage
coverage/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# K8s secrets (never in image)
production/k8s/*.secret.yaml
